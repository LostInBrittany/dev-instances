# Build output: packed VM blobs and pack-stub binaries.
# Each blueprint's build.sh writes its .smolmachine + stub here.
dist/

# Belt-and-suspenders: catch any .smolmachine written outside dist/.
*.smolmachine

# Legacy: pack-stub binaries from earlier builds that landed at the repo
# root before dist/ existed. Safe to delete locally; ignored so they
# don't sneak into commits.
/ubuntu-dev
/bun-dev
/bun-only

# macOS
.DS_Store
