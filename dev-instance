#!/usr/bin/env bash
#
# dev-instance — per-project sandbox manager built on smolvm.
#
# Creates, manages, and destroys per-project VM clones from prebuilt
# blueprints (or any OCI image). Mounts $PWD into the clone as
# ~/workspace. Blueprint clones run as a `dev` user whose uid/gid match
# the host user's, so files written inside the mount keep host
# ownership without a post-session chown. --image clones default to
# root (the original setup) since the matching scripts only exist in
# our blueprints. No credentials enter the clone by default.
#
# Repo location is auto-detected from this script's path (so symlinks
# into ~/.local/bin/ work). Override with $DEV_INSTANCES_ROOT.

set -euo pipefail

usage() {
    cat <<'EOF'
dev-instance — per-project sandbox manager built on smolvm.

Usage:
  dev-instance create [BLUEPRINT]      Create + start a clone from a blueprint
                                       (default: bun-only).
  dev-instance create --image IMG      Create + start a clone from any OCI image
                                       (no Claude Code preinstalled).
  dev-instance create --copy-claude    Also copy host's ~/.claude config (settings,
                                       skills, agents, hooks, plugins, statusline)
                                       into the clone. Blueprint-mode only.
  dev-instance shell [NAME]            Exec into a clone (auto-detected from
                                       cwd if exactly one matches).
  dev-instance stop  [NAME]            Stop a running clone.
  dev-instance rm    [NAME]            Delete a clone (also stops if running).
  dev-instance clean [-f|--force]      Stop + delete every clone for cwd.
                                       Prompts unless -f.
  dev-instance ls    [--all]           List clones for cwd, or all clones.
  dev-instance build [BLUEPRINT] [--rebuild]
                                       Build a blueprint (default: bun-only).
                                       Re-packs the existing source VM if
                                       one exists; --rebuild to start fresh
                                       from the base image.
  dev-instance build --all [--rebuild] Build every blueprint in blueprints/.
  dev-instance new-blueprint NAME --image IMG
                                       Scaffold blueprints/NAME/ with a
                                       build.sh that installs Claude Code on
                                       top of IMG. Edit it to add your tools,
                                       then run it.
  dev-instance help                    This message.

Clones are auto-named "<cwd-basename>-<4 hex>". $PWD is mounted as
~/workspace; `dev-instance shell` lands you there.
EOF
}

die() { echo "dev-instance: $*" >&2; exit 1; }

need_smolvm() {
    command -v smolvm >/dev/null 2>&1 && return
    cat >&2 <<'EOF'
dev-instance: smolvm is not installed or not on PATH.

  Install:  brew tap smol-machines/tap && brew install smolvm
  Or:       https://github.com/smol-machines/smolvm

This tool wraps smolvm to manage per-project sandbox VMs; nothing
beyond `help` and `new-blueprint` works without it.
EOF
    exit 1
}

# Resolve repo root: env var wins, else follow symlinks from $0.
if [[ -n "${DEV_INSTANCES_ROOT:-}" ]]; then
    REPO_ROOT="$DEV_INSTANCES_ROOT"
else
    SCRIPT_PATH="$0"
    while [[ -L "$SCRIPT_PATH" ]]; do
        TARGET="$(readlink "$SCRIPT_PATH")"
        case "$TARGET" in
            /*) SCRIPT_PATH="$TARGET" ;;
            *)  SCRIPT_PATH="$(dirname "$SCRIPT_PATH")/$TARGET" ;;
        esac
    done
    REPO_ROOT="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
fi
DIST="$REPO_ROOT/dist"

generate_name() {
    echo "$(basename "$PWD")-$(openssl rand -hex 2)"
}

# All VM names known to smolvm. Uses --json because the plain `ls` output
# truncates the NAME column at ~16 chars + "..." and uses space-padded
# columns, which makes substring matching unreliable.
all_vm_names() {
    smolvm machine ls --json 2>/dev/null \
        | grep -oE '"name"[[:space:]]*:[[:space:]]*"[^"]*"' \
        | sed -E 's/.*"([^"]*)"$/\1/'
}

# Names of all clones that look like they belong to $PWD (prefix-<4 hex>).
# Empty (not an error) if no matches.
clones_for_cwd() {
    local prefix
    prefix="$(basename "$PWD")-"
    all_vm_names \
        | grep -E "^${prefix}[0-9a-f]{4}$" \
        | sort -u \
        || true
}

# Resolve clone name from optional argument; auto-detect from $PWD if absent.
resolve_name() {
    local arg="${1:-}"
    if [[ -n "$arg" ]]; then
        echo "$arg"; return
    fi
    local matches; matches="$(clones_for_cwd)"
    local count; count="$(printf '%s' "$matches" | grep -c . || true)"
    if [[ "$count" == "0" ]]; then
        die "no clone found for $(basename "$PWD"). Run: dev-instance create"
    elif [[ "$count" == "1" ]]; then
        echo "$matches"
    else
        echo "dev-instance: multiple clones for $(basename "$PWD"):" >&2
        echo "$matches" | sed 's/^/  /' >&2
        die "specify a name explicitly"
    fi
}

cmd_create() {
    local blueprint="" image="" copy_claude=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image)       image="${2:-}"; shift 2 || die "--image needs a value" ;;
            --copy-claude) copy_claude=true; shift ;;
            -h|--help)     usage; return 0 ;;
            -*)            die "unknown flag: $1" ;;
            *)             blueprint="$1"; shift ;;
        esac
    done
    [[ -n "$blueprint" && -n "$image" ]] && die "pass a blueprint OR --image, not both"
    $copy_claude && [[ -n "$image" ]] && die "--copy-claude is blueprint-only (--image clones run as root, no dev user)"

    local name; name="$(generate_name)"

    if [[ -n "$image" ]]; then
        # Raw image mode: no dev user, mount at /root/workspace, runs as root.
        smolvm machine create "$name" --image "$image" --net \
            -v "$PWD:/root/workspace" -w /root/workspace
    else
        blueprint="${blueprint:-bun-only}"
        local pack="$DIST/${blueprint}.smolmachine"
        [[ -f "$pack" ]] || die "blueprint '$blueprint' not built. Run: dev-instance build $blueprint"
        # Blueprint mode: pass host uid/gid + the runtime user-matching
        # script via --init, mount at /home/dev/workspace.
        smolvm machine create "$name" --from "$pack" --net \
            -v "$PWD:/home/dev/workspace" -w /home/dev/workspace \
            -e "HOST_UID=$(id -u)" -e "HOST_GID=$(id -g)" \
            --init /usr/local/sbin/match-host-uid.sh
    fi

    smolvm machine start --name "$name"

    if $copy_claude; then
        # `smolvm machine start --init ...` returns before init has
        # finished. If we exec into the VM too soon we race the dev-user
        # setup in match-host-uid.sh — the symptom is a clone that comes
        # up as root instead of dev. Poll for the dev user first.
        wait_for_dev_user "$name"
        copy_claude_settings "$name"
        # `smolvm machine cp` reverts the writable filesystem on
        # --from <pack> machines, so the dev user created by --init
        # disappears. Re-run match-host-uid.sh to recreate it (and
        # re-chown /home/dev so our copied files end up owned by the
        # host uid:gid). Pass HOST_UID/HOST_GID explicitly via env so
        # this works even if the machine-level env vars set at create
        # time don't propagate into exec.
        # Tracking upstream: smol-machines/smolvm#264.
        smolvm machine exec --name "$name" -- env \
            "HOST_UID=$(id -u)" "HOST_GID=$(id -g)" \
            /usr/local/sbin/match-host-uid.sh
    fi

    echo "$name"
}

# Poll until the dev user (created by --init / match-host-uid.sh) exists.
# `smolvm machine start --init ...` returns before init has actually
# finished, so blowing past it into `machine exec` can race the user
# setup. Symptom: clone comes up as root instead of dev.
wait_for_dev_user() {
    local vm_name="$1" tries=0
    while ! smolvm machine exec --name "$vm_name" -- id dev >/dev/null 2>&1; do
        ((tries++))
        if (( tries > 60 )); then
            die "timed out waiting for dev user (init may have failed)"
        fi
        sleep 0.5
    done
}

# Copy a Claude Code config allowlist from ~/.claude/ on the host into
# /home/dev/.claude/ inside the clone, then chown to the host uid:gid
# so the `dev` user owns it. Allowlist is config + personalization +
# user-level memory only; runtime/history (sessions/, projects/,
# todos/, statsig/, shell-snapshots/, history.jsonl, caches, telemetry
# etc.) is explicitly skipped — see BACKLOG.md.
copy_claude_settings() {
    local vm_name="$1"

    if [[ ! -d "$HOME/.claude" ]]; then
        echo "dev-instance: no ~/.claude on host; skipping --copy-claude" >&2
        return 0
    fi

    local items=(
        settings.json
        CLAUDE.md
        skills
        agents
        commands
        hooks
        plugins
        statusline.sh
        statusline.js
        claude-quota.js
    )

    local present=() item
    for item in "${items[@]}"; do
        [[ -e "$HOME/.claude/$item" ]] && present+=("$item")
    done

    if [[ ${#present[@]} -eq 0 ]]; then
        echo "dev-instance: no Claude config items present in ~/.claude; nothing to copy" >&2
        return 0
    fi

    echo "==> Copying Claude Code config (${#present[@]} items) into $vm_name..."

    local tmptar
    tmptar="$(mktemp -t devinst-claude.XXXXXX.tar)"
    # shellcheck disable=SC2064
    trap "rm -f '$tmptar'" RETURN

    # Strip macOS extended attributes and AppleDouble metadata so the
    # VM's GNU tar doesn't warn about LIBARCHIVE.xattr.* pax headers
    # and doesn't unpack ._* AppleDouble companions. Both flags are
    # feature-detected so this is safe on Linux hosts too.
    #
    # --dereference follows symlinks and archives their target content
    # as real files. Without it, a symlink like
    # ~/.claude/skills/clever-tools → /Users/horacio/projects/... would
    # land in the VM as a symlink to a host path that doesn't exist
    # there, breaking both the skill and the subsequent chown.
    local tar_flags=(--dereference)
    if tar --no-xattrs --version >/dev/null 2>&1; then
        tar_flags+=(--no-xattrs)
    fi
    if tar --no-mac-metadata --version >/dev/null 2>&1; then
        tar_flags+=(--no-mac-metadata)
    fi
    tar c "${tar_flags[@]}" -C "$HOME/.claude" -f "$tmptar" "${present[@]}"
    smolvm machine cp "$tmptar" "$vm_name:/tmp/claude-cfg.tar"
    smolvm machine exec --name "$vm_name" -- bash -c "
        set -e
        mkdir -p /home/dev/.claude
        tar x -C /home/dev/.claude -f /tmp/claude-cfg.tar
        rm /tmp/claude-cfg.tar
        chown -R $(id -u):$(id -g) /home/dev/.claude
    "
}

cmd_shell() {
    local name; name="$(resolve_name "${1:-}")"
    # If the clone has a `dev` user (blueprint mode), drop in as them in
    # /home/dev/workspace. Otherwise (raw --image mode) fall back to root
    # in /root/workspace.
    #
    # Note: terminal size inside the clone is currently stuck at 80x24
    # regardless of host width. smolvm 0.6.3's SIGWINCH forwarding isn't
    # taking effect for us — tracked alongside smolvm#156. Nothing we
    # can do from inside the VM helps (in-VM stty is overridden by
    # smolvm, bash resets COLUMNS from TIOCGWINSZ at startup). Waiting
    # on upstream.
    if smolvm machine exec --name "$name" -- id dev >/dev/null 2>&1; then
        exec smolvm machine exec --name "$name" -w /home/dev/workspace -it -- \
            runuser -u dev -- bash -l
    else
        exec smolvm machine exec --name "$name" -w /root/workspace -it -- bash -l
    fi
}

cmd_stop() {
    local name; name="$(resolve_name "${1:-}")"
    smolvm machine stop --name "$name"
}

cmd_rm() {
    local name; name="$(resolve_name "${1:-}")"
    smolvm machine stop --name "$name" 2>/dev/null || true
    smolvm machine delete "$name" -f
}

# Stop + delete every clone whose name matches the cwd's prefix.
# Prompts unless -f. Continues on per-clone failures, exits nonzero if any.
cmd_clean() {
    local force=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -f|--force) force=true; shift ;;
            -h|--help)  usage; return 0 ;;
            -*)         die "unknown flag: $1" ;;
            *)          die "unexpected arg: $1" ;;
        esac
    done

    local matches; matches="$(clones_for_cwd)"
    if [[ -z "$matches" ]]; then
        echo "(no clones for $(basename "$PWD"))"
        return 0
    fi

    if ! $force; then
        echo "The following clones for $(basename "$PWD") will be stopped and deleted:"
        echo "$matches" | sed 's/^/  /'
        printf 'Proceed? [y/N] '
        local answer=""
        read -r answer || true
        case "$answer" in
            y|Y|yes|YES) ;;
            *) echo "aborted."; return 1 ;;
        esac
    fi

    local rc=0 name
    while IFS= read -r name; do
        [[ -n "$name" ]] || continue
        echo "==> $name"
        smolvm machine stop --name "$name" 2>/dev/null || true
        if ! smolvm machine delete "$name" -f; then
            echo "dev-instance: failed to delete $name" >&2
            rc=1
        fi
    done <<< "$matches"
    return $rc
}

cmd_ls() {
    if [[ "${1:-}" == "--all" ]]; then
        smolvm machine ls
    else
        local matches; matches="$(clones_for_cwd)"
        if [[ -z "$matches" ]]; then
            echo "(no clones for $(basename "$PWD"))"
        else
            echo "$matches"
        fi
    fi
}

cmd_build() {
    local blueprint="" all=false
    local script_args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all)     all=true; shift ;;
            --rebuild) script_args+=("$1"); shift ;;
            -h|--help) usage; return 0 ;;
            -*)        die "unknown flag: $1" ;;
            *)         if [[ -z "$blueprint" ]]; then blueprint="$1"; else die "unexpected arg: $1"; fi; shift ;;
        esac
    done

    if $all; then
        [[ -n "$blueprint" ]] && die "pass a blueprint name OR --all, not both"
        local script
        for script in "$REPO_ROOT/blueprints/"*/build.sh; do
            [[ -x "$script" ]] || continue
            echo "=== building $(basename "$(dirname "$script")") ==="
            "$script" ${script_args[@]+"${script_args[@]}"}
        done
        return
    fi

    blueprint="${blueprint:-bun-only}"
    local script="$REPO_ROOT/blueprints/$blueprint/build.sh"
    [[ -f "$script" ]] || die "no such blueprint: $blueprint (looked for $script)"
    exec "$script" ${script_args[@]+"${script_args[@]}"}
}

cmd_new_blueprint() {
    local name="" image=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image) image="${2:-}"; shift 2 || die "--image needs a value" ;;
            -h|--help) usage; return 0 ;;
            -*) die "unknown flag: $1" ;;
            *)  if [[ -z "$name" ]]; then name="$1"; else die "unexpected arg: $1"; fi; shift ;;
        esac
    done
    [[ -n "$name"  ]] || die "new-blueprint needs a NAME"
    [[ -n "$image" ]] || die "new-blueprint needs --image IMG"
    [[ "$name" =~ ^[a-zA-Z0-9][a-zA-Z0-9_-]*$ ]] || die "name must match [a-zA-Z0-9_-]+ and start alphanumeric"

    local target="$REPO_ROOT/blueprints/$name"
    [[ -e "$target" ]] && die "$target already exists; refusing to overwrite"

    mkdir -p "$target"
    printf 'net = true\n' > "$target/pack.smolfile"

    sed -e "s|__NAME__|$name|g" -e "s|__IMAGE__|$image|g" > "$target/build.sh" <<'TEMPLATE'
#!/usr/bin/env bash
#
# Build the __NAME__ blueprint.
#
# Scaffolded by `dev-instance new-blueprint`. Starts from __IMAGE__.
# Edit the prereqs block below to add tools your projects need
# (Node, Bun, Python deps, etc.) before running.
#
# Lifecycle (handled by the shared blueprints/_build-lib.sh):
#   - re-packs the existing source VM if it exists (fast);
#   - otherwise creates it from $IMAGE, runs the prereqs block below,
#     then sources the shared user-matching + agent-CLIs installers,
#     stops the VM, and packs it into dist/$NAME.smolmachine.
#   - --rebuild deletes the existing source VM first.

set -euo pipefail

NAME="__NAME__"
IMAGE="__IMAGE__"

# shellcheck source=../_build-lib.sh
source "$(cd "$(dirname "$0")" && pwd)/../_build-lib.sh"

build_with_prereqs "$@" -- bash -c '
set -euo pipefail

# Minimal prereqs — try common package managers in order.
if command -v apt-get >/dev/null; then
    export DEBIAN_FRONTEND=noninteractive
    apt-get update -qq
    apt-get install -y -qq --no-install-recommends curl ca-certificates bash sudo
elif command -v apk >/dev/null; then
    apk add --no-cache curl ca-certificates bash sudo
elif command -v dnf >/dev/null; then
    dnf install -y curl ca-certificates bash sudo
elif command -v yum >/dev/null; then
    yum install -y curl ca-certificates bash sudo
else
    echo "ERROR: no supported package manager (apt-get/apk/dnf/yum). Install curl + ca-certificates + sudo manually above this block." >&2
    exit 1
fi

# --- Add your custom installs here (Node, Bun, Python deps, etc.) ---

'
TEMPLATE

    chmod +x "$target/build.sh"

    cat <<EOF
Scaffolded: blueprints/$name/
  build.sh       — edit the "Add your custom installs here" block, then run it
  pack.smolfile  — pack config (net = true)

Next:
  \$EDITOR blueprints/$name/build.sh
  dev-instance build $name
  dev-instance create $name
EOF
}

sub="${1:-help}"; shift || true
case "$sub" in
    create)         need_smolvm; cmd_create        "$@" ;;
    shell)          need_smolvm; cmd_shell         "$@" ;;
    stop)           need_smolvm; cmd_stop          "$@" ;;
    rm)             need_smolvm; cmd_rm            "$@" ;;
    clean)          need_smolvm; cmd_clean         "$@" ;;
    ls)             need_smolvm; cmd_ls            "$@" ;;
    build)          need_smolvm; cmd_build         "$@" ;;
    new-blueprint)  cmd_new_blueprint              "$@" ;;
    help|--help|-h) usage ;;
    *)              die "unknown subcommand: $sub. Try: dev-instance help" ;;
esac
